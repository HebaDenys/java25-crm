{
  "name": "java25-crm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend"
  ],
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:infra": "docker compose up -d postgres keycloak",
    "dev:postgres": "docker compose up -d postgres",
    "dev:backend": "mvn -f backend/pom.xml spring-boot:run",
    "dev:frontend": "npm --workspace frontend run dev -- --host 0.0.0.0",
    "build": "npm run build:frontend && npm run build:backend",
    "build:backend": "mvn -f backend/pom.xml -DskipTests package",
    "build:frontend": "npm --workspace frontend run build",
    "check": "npm run test && npm run build",
    "test": "npm run test:frontend && npm run test:backend",
    "test:backend": "mvn -f backend/pom.xml test",
    "test:frontend": "npm --workspace frontend run lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}